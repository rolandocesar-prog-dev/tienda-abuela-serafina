# ====================================================================
# Variables de entorno para Tienda Abuela Serafina
# Copia este archivo como `.env` y ajusta los valores que necesites.
# ====================================================================

# --- PostgreSQL (una BD por servicio, mismo usuario/pass para simplicidad) ---
POSTGRES_USER=tienda
POSTGRES_PASSWORD=tienda
POSTGRES_PORT_PRODUCT=54321
POSTGRES_PORT_INVENTORY=54322
POSTGRES_PORT_SALES=54323
POSTGRES_PORT_CUSTOMER=54324
POSTGRES_PORT_NOTIFICATION=54325
POSTGRES_PORT_AUTH=54326
POSTGRES_PORT_COMPANY=54327

# --- Broker (RabbitMQ) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- JWT (Auth Service) ---
# El owner de Auth Service genera un secret real. Para dev queda este placeholder.
JWT_SECRET=dev-secret-cambiar-en-prod

# --- Frontend ---
# URL base por la que el frontend llamará al gateway
GATEWAY_URL=http://localhost:8000
