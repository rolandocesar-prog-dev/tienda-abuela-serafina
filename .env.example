# ====================================================================
# Variables de entorno para Tienda Abuela Serafina
# Copia este archivo como `.env` y ajusta los valores que necesites.
# ====================================================================

# --- PostgreSQL (una BD por servicio, mismo usuario/pass para simplicidad) ---
POSTGRES_USER=tienda
POSTGRES_PASSWORD=tienda
POSTGRES_PORT_CATALOG=54321
POSTGRES_PORT_ALMACEN=54322
POSTGRES_PORT_VENTAS=54323
POSTGRES_PORT_COMPRAS=54324
POSTGRES_PORT_PAGOS=54325
POSTGRES_PORT_FACTURACION=54326
POSTGRES_PORT_RRHH=54327

# --- Stripe (modo test) ---
# Obtenlas en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR

# --- Frontend ---
# URL base por la que el frontend llamará al gateway
GATEWAY_URL=http://localhost:8000
